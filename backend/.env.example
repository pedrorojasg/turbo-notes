# Copy to .env for local development.
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=dev-secret-change-me
DJANGO_DEBUG=1

# Local Postgres (matches docker-compose). Omit to fall back to sqlite.
DATABASE_URL=postgres://notes:notes@localhost:5432/notes

ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# JWT lifetimes
ACCESS_TOKEN_LIFETIME_MIN=30
REFRESH_TOKEN_LIFETIME_DAYS=7

# ---------------------------------------------------------------------------
# Production (Railway backend + Supabase Postgres) — set these in the Railway
# service variables, NOT in a committed file.
# ---------------------------------------------------------------------------
# DJANGO_SETTINGS_MODULE=config.settings.prod
# SECRET_KEY=<generate a long random string>
# DJANGO_DEBUG=0
#
# Supabase connection string. Use the "Session pooler" URI from the Supabase
# dashboard (Project Settings → Database → Connection string → URI). It already
# includes the user, password, host and port (5432 direct / 6543 pooler).
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
#
# Railway gives the service a public domain — put its host here (no scheme).
# ALLOWED_HOSTS=turbo-notes-api.up.railway.app
# CSRF_TRUSTED_ORIGINS=https://turbo-notes-api.up.railway.app
#
# The deployed Vercel frontend origin (scheme + host, no trailing slash).
# CORS_ALLOWED_ORIGINS=https://turbo-notes.vercel.app
